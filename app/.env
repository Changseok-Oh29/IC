# ─────────────────────────────────────────────────────────────────────────────
# IC Docker Environment — JetPack 6.2.1
#
# Copy this file to app/.env and adjust values for your Jetson setup.
# docker compose reads this automatically.
# ─────────────────────────────────────────────────────────────────────────────

# User ID of the Jetson user (avees = 1000)
UID=1000
GID=1000

# Host Wayland display socket (GNOME Wayland on JetPack 6.2.1 = wayland-0)
# Check with: echo $WAYLAND_DISPLAY  (must be run in a Wayland session)
WAYLAND_DISPLAY=wayland-0
